<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="600" prefWidth="700" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.demo1.MainWindowController">

  <!-- Кнопки старые -->
  <Button fx:id="btn_run" layoutX="30" layoutY="20" text="Run Here" onAction="#run_here"/>
  <Button fx:id="btn_run_separ_thrd" layoutX="150" layoutY="20" text="Run in Thread" onAction="#run_in_thread2"/>
  <Button fx:id="btn_stop" layoutX="300" layoutY="20" text="Stop" onAction="#stop"/>

  <!-- Новые элементы для параллельной сортировки -->
  <Label layoutX="30" layoutY="70" text="Потоков:"/>
  <TextField fx:id="threadsField" layoutX="100" layoutY="65" prefWidth="60" text="4"/>

  <Label layoutX="190" layoutY="70" text="Размер массива:"/>
  <TextField fx:id="arraySizeField" layoutX="300" layoutY="65" prefWidth="100" text="12000"/>

  <Button layoutX="430" layoutY="60" text="Параллельный алгоритм" onAction="#runParallelBubble" prefHeight="30"/>

  <Label fx:id="timeLabel" layoutX="30" layoutY="520" text="Время: " style="-fx-font-weight: bold;"/>

  <!-- Поля вывода массивов -->
  <Label layoutX="30" layoutY="110" text="Исходный массив:"/>
  <TextArea fx:id="area_old" layoutX="30" layoutY="130" prefHeight="180" prefWidth="640"/>

  <Label layoutX="30" layoutY="320" text="Результат:"/>
  <TextArea fx:id="area_new" layoutX="30" layoutY="340" prefHeight="170" prefWidth="640"/>

  <ProgressBar fx:id="progressBar" layoutX="30" layoutY="550" prefWidth="640" progress="0.0"/>

</AnchorPane>