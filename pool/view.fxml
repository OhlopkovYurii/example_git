<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="420.0" prefWidth="550.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.threads_pool.Controller">
    <Label layoutX="20" layoutY="20" text="Количество потоков:" />
    <TextField fx:id="num_threads" layoutX="160" layoutY="15" prefWidth="80" text="2" />

    <Label layoutX="280" layoutY="20" text="Размер массива (миллионов):" />
    <TextField fx:id="num_elem" layoutX="420" layoutY="15" prefWidth="100" text="50" />

    <Button fx:id="btn_run" layoutX="30" layoutY="70" text="Старт" onAction="#run_here" />
    <Button fx:id="btn_stop" layoutX="150" layoutY="70" text="Остановить" onAction="#stop" />

    <TextArea fx:id="area_old" layoutX="20" layoutY="120" prefHeight="110" prefWidth="500" promptText="Информация о задаче" />
    <TextArea fx:id="area_new" layoutX="20" layoutY="250" prefHeight="110" prefWidth="500" promptText="Результат" />
</AnchorPane>